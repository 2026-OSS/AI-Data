.DS_Store
.cache/
.venv/
venv/
env/
__pycache__/
*.py[cod]

# Keep only backend handoff files in the YOLOv5 v2 artifact directory.
artifacts/yolov5-v2/*
!artifacts/yolov5-v2/
!artifacts/yolov5-v2/README.md
!artifacts/yolov5-v2/best.pt
!artifacts/yolov5-v2/data.yaml

# Keep only backend handoff files in the YOLOv5 v6 artifact directory.
artifacts/yolov5-v6/*
!artifacts/yolov5-v6/
!artifacts/yolov5-v6/README.md
!artifacts/yolov5-v6/best.pt
!artifacts/yolov5-v6/data.yaml

# Keep only backend handoff files in the YOLO11n v12 artifact directory.
artifacts/yolo11-v12/*
